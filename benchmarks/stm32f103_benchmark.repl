nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    priorityMask: 0xFF
    systickFrequency: 72000000
    IRQ -> cpu@0

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m3"
    nvic: nvic

flash: Memory.MappedMemory @ sysbus 0x08000000
    size: 0x00080000

ram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x00010000
